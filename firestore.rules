rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Business doc: only the owner (who created it) can read/write
    match /businesses/{businessId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      // All subcollections under a business
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null;
      }

      // Nested subcollections (e.g. parties/{partyId}/transactions/{txnId})
      match /{subcollection}/{docId}/{nested}/{nestedId} {
        allow read, write: if request.auth != null;
      }
    }

    // Public business directory — anyone authenticated can read, only owner can write
    match /public_directory/{directoryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}